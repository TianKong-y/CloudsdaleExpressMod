{
  "schemaVersion": 1,
  "id": "cloudsdaleexpress",
  "version": "${version}",
  "name": "CloudsdaleExpress",
  "description": "CloudsdaleExpress high-speed minecart compatibility mod for Fabric ${minecraft_version}",
  "authors": [
    "TianKong_y"
  ],
  "environment": "*",
  "entrypoints": {
    "main": [
      "com.smoothquartz.minecart.SmoothQuartzServer"
    ],
    "client": [
      "com.smoothquartz.minecart.SmoothQuartzClient"
    ]
  },
  "mixins": [
    "mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "minecraft": "${minecraft_version}",
    "fabric-api": "*",
    "java": ">=21"
  }
}
